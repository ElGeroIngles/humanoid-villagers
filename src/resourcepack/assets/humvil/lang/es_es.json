  "names.humvil.conversation.1.participants.1.line.1": "Vaya, ¡cuánto tiempo %s!",
  "names.humvil.conversation.1.participants.1.line.2": "¿Cómo te va?",
  "names.humvil.conversation.2.participants.1.line.1": "Ojalá llueva pronto, mola mucho ver cómo llueve.",
  "names.humvil.conversation.3.participants.1.line.1": "Qué buen tiempo hace hoy, ¿no crees?",
  "names.humvil.conversation.4.participants.1.line.1": "¡Un Golem de Hierro! Por fin me siento un poco más seguro aquí.",
  "names.humvil.conversation.5.participants.1.line.1": "Me pregunto si %s querrá comprarme algo...",
  "names.humvil.conversation.6.participants.1.line.1": "¡Qué vistas tan bonitas tengo desde aquí!",
  "names.humvil.conversation.7.participants.1.line.1": "Hoy no tengo ganas de trabajar, creo que me quedaré embobado un ratito...",
  "names.humvil.conversation.8.participants.1.line.1": "...",
  "names.humvil.conversation.8.participants.1.line.2": "......",
  "names.humvil.conversation.8.participants.1.line.3": ".........",
  "names.humvil.conversation.8.participants.1.line.4": "............",
  "names.humvil.conversation.8.participants.1.line.5": "...............",
  "names.humvil.conversation.8.participants.1.line.6": "Creo que iba a decir algo...",
  "names.humvil.conversation.8.participants.1.line.7": "Pero me parece que se me ha olidado...",
  "names.humvil.conversation.9.participants.1.line.1": "Mmmm...",
  "names.humvil.conversation.9.participants.1.line.2": "Iba a hacer algo pero ya no me acuerdo qué era...",
  "names.humvil.conversation.10.participants.1.line.1": "¿Mmmm? (¿Esperando que suceda algo?)",
  "names.humvil.conversation.11.participants.1.line.1": "Mira %s, que te cuento un chiste.",
  "names.humvil.conversation.11.participants.1.line.2": "Van dos...",
  "names.humvil.conversation.11.participants.1.line.3": "Y..",
  "names.humvil.conversation.11.participants.1.line.4": "No, mentira, van 3... y el del lado...",
  "names.humvil.conversation.11.participants.1.line.5": "No, joder, así no...",
  "names.humvil.conversation.11.participants.1.line.6": "Y 50 topitos se caen...",
  "names.humvil.conversation.11.participants.1.line.7": "Nada.. olvídalo... no me acuerdo cómo era, otro día te lo cuento.",
  "names.humvil.conversation.11.participants.1.line.8": "(Ostia, que vergüenza... se va a pensar que soy tontito...)",

  "names.humvil.conversation.1.participants.2.line.1": "¡Eh, %s! ¿Has visto al Golem últimamente?",
  "names.humvil.conversation.1.participants.2.line.2": "Sí, estaba patrullando cerca de aquí hace nada.",
  "names.humvil.conversation.2.participants.2.line.1": "Te cambio 3 panes por una esmeralda.",
  "names.humvil.conversation.2.participants.2.line.2": "¡Ni hablar! %s, eso es un robo a mano armada.",
  "names.humvil.conversation.3.participants.2.line.1": "Cuidado, %s, creo que hay algo detrás de ese árbol.",
  "names.humvil.conversation.3.participants.2.line.2": "Claro tonto, ¡si soy yo!",
  "names.humvil.conversation.4.participants.2.line.1": "Hola vecino, ¿qué tal has dormido?",
  "names.humvil.conversation.4.participants.2.line.2": "Fatal, %s. Habían monstruos cerca y no pude dormir bien.",
  "names.humvil.conversation.5.participants.2.line.1": "Oye %s, deja de pisar mis cultivos.",
  "names.humvil.conversation.5.participants.2.line.2": "Uis, perdón, no me di cuenta.",
  "names.humvil.conversation.5.participants.2.line.3": "Ya te vale...",
  "names.humvil.conversation.6.participants.2.line.1": "Mira eso, %s lleva una armadura muy buena.",
  "names.humvil.conversation.6.participants.2.line.2": "Seguro que ha estado en la mina durante días, %s.",
  "names.humvil.conversation.7.participants.2.line.1": "¿Has escuchado eso? ¿Es una invasión?",
  "names.humvil.conversation.7.participants.2.line.2": "Tranquilo %s, tenemos a %s, no nos pasará nada.",
  "names.humvil.conversation.8.participants.2.line.1": "Me encanta tu profesión, %s.",
  "names.humvil.conversation.8.participants.2.line.2": "Gracias %s, me gusta bastante.",
  "names.humvil.conversation.9.participants.2.line.1": "%s, ¿me prestas un poco de carbón?",
  "names.humvil.conversation.9.participants.2.line.2": "Lo siento, se lo vendí todo a %s ayer.",
  "names.humvil.conversation.10.participants.2.line.1": "Quiero explorar más allá de la aldea.",
  "names.humvil.conversation.10.participants.2.line.2": "¿Por qué? Aquí se está a salvo.",
  "names.humvil.conversation.10.participants.2.line.3": "Ese es el problema. ¡No pasa nada nunca!",
  "names.humvil.conversation.10.participants.2.line.4": "Amigo, la paz es una bendición.",
  "names.humvil.conversation.10.participants.2.line.5": "Para tí, quizás. Para mi, es una carcel. Necesito aventura.",

  "names.humvil.conversation.1.participants.3.line.1": "¿Alguien sabe dónde está la entrada a la mina?",
  "names.humvil.conversation.1.participants.3.line.2": "Creo que %s la tapó.",
  "names.humvil.conversation.1.participants.3.line.3": "No, %s, la entrada está detrás de la colina, yo la vi.",
  "names.humvil.conversation.2.participants.3.line.1": "¡Reunión en el pozo!",
  "names.humvil.conversation.2.participants.3.line.2": "¿Qué pasa ahora, %s? Estoy ocupado.",
  "names.humvil.conversation.2.participants.3.line.3": "Seguro quiere hablar de las esmeraldas otra vez.",
  "names.humvil.conversation.3.participants.3.line.1": "Esa espada que lleva %s brilla mucho.",
  "names.humvil.conversation.3.participants.3.line.2": "Debe estar encantada.",
  "names.humvil.conversation.3.participants.3.line.3": "Ojalá poder usar una para defenderme de los zombies...",
  "names.humvil.conversation.4.participants.3.line.1": "Tengo hambre, ¿alguien tiene zanahorias?",
  "names.humvil.conversation.4.participants.3.line.2": "Pregúntale a %s, creo que él tiene algunas.",
  "names.humvil.conversation.4.participants.3.line.3": "Lo siento chicos, ya les di las que me quedaban a otros.",
  "names.humvil.conversation.5.participants.3.line.1": "Hrmm...",
  "names.humvil.conversation.5.participants.3.line.2": "Hrmm-hrmm...",
  "names.humvil.conversation.5.participants.3.line.3": "Es verdad, concuerdo con vosotros.",
  "names.humvil.conversation.6.participants.3.line.1": "Esta aldea necesita más camas.",
  "names.humvil.conversation.6.participants.3.line.2": "Díselo a %s, es quien las está quitanto todo el rato y moviéndolas a un cubículo.",
  "names.humvil.conversation.6.participants.3.line.3": "¿Ah si? Me pregunto por qué estará haciendo eso...",
  "names.humvil.conversation.7.participants.3.line.1": "¡Defiendo todo lo que es amado!",
  "names.humvil.conversation.7.participants.3.line.2": "Ehhh, vale.",
  "names.humvil.conversation.7.participants.3.line.3": "Solo Dios puede detener a este paladín; por desgracia, mi tiempo llegó y se fue.",
  "names.humvil.conversation.7.participants.3.line.4": "Claro... supongo que yo también empuño una espada, ¿y tú?",
  "names.humvil.conversation.7.participants.3.line.5": "De vez en cuando.",
  "names.humvil.conversation.7.participants.3.line.6": "Debe de ser una época maravillosa para ser un joven muchacho, ¡ven un día y podremos tomar una o dos copas!",
  "names.humvil.conversation.7.participants.3.line.7": "Yo... prefiero no hacerlo.",
  "names.humvil.conversation.7.participants.3.line.8": "¿Qué edad tiene para hablar así?",

  "names.humvil.conversation.1.participants.4.line.1": "Oye, creo que deberíamos mudarnos.",
  "names.humvil.conversation.1.participants.4.line.2": "¿Por qué? Aquí tenemos comida y protección.",
  "names.humvil.conversation.1.participants.4.line.3": "%s tiene razón, hay demasiados zombies por la noche.",
  "names.humvil.conversation.1.participants.4.line.4": "Yo me quedo, %s prometió protegernos.",
  "names.humvil.conversation.2.participants.4.line.1": "¿Quién ha robado mi mesa de trabajo?",
  "names.humvil.conversation.2.participants.4.line.2": "Yo no fui, estaba con %s.",
  "names.humvil.conversation.2.participants.4.line.3": "Es cierto, estábamos en otra parte.",
  "names.humvil.conversation.2.participants.4.line.4": "¡Creo que vi a %s llevársela!.",
  "names.humvil.conversation.3.participants.4.line.1": "¡Fiesta en el centro del pueblo!",
  "names.humvil.conversation.3.participants.4.line.2": "¿Qué celebramos?",
  "names.humvil.conversation.3.participants.4.line.3": "¡Que hemos sobrevivido a otra noche!",
  "names.humvil.conversation.3.participants.4.line.4": "¡Y que %s ha bajado sus precios por fin!",
  "names.humvil.conversation.4.participants.4.line.1": "Hrmm...",
  "names.humvil.conversation.4.participants.4.line.2": "Hrmm!",
  "names.humvil.conversation.4.participants.4.line.3": "Hrmm... Hrmm?",
  "names.humvil.conversation.4.participants.4.line.4": "¿Cómo? ¿Qué la End Update va a salir cuándo?",
  "names.humvil.conversation.5.participants.4.line.1": "Necesito papel. Mucho papel.",
  "names.humvil.conversation.5.participants.4.line.2": "Yo tengo cuero, podemos hacer libros.",
  "names.humvil.conversation.5.participants.4.line.3": "Yo puedo encantar esos libros si me traéis lapislázuli.",
  "names.humvil.conversation.5.participants.4.line.4": "Y yo se los venderé a %s por una fortuna. ¡Equipo perfecto!",
  "names.humvil.conversation.6.participants.4.line.1": "Creo que lloverá dentro de poco.",
  "names.humvil.conversation.6.participants.4.line.2": "Odio la lluvia, los Enderman se ponen agresivos.",
  "names.humvil.conversation.6.participants.4.line.3": "Pero es buena para la pesca, ¿verdad %s?",
  "names.humvil.conversation.6.participants.4.line.4": "Sí, pero prefiero quedarme en casa tranquilito con %s.",
  "names.humvil.conversation.7.participants.4.line.1": "Awwww, ¡mirad que mono el Bebé Aldeano!",
  "names.humvil.conversation.7.participants.4.line.2": "¡Qué energía tiene!",
  "names.humvil.conversation.7.participants.4.line.3": "Está saltando en mi cama, ¡haced que pare!",
  "names.humvil.conversation.7.participants.4.line.4": "Dejadlo, solo está jugando.",
  "names.humvil.conversation.8.participants.4.line.1": "¿Alguien ha visto al Golem?",
  "names.humvil.conversation.8.participants.4.line.2": "Creo que se cayó en un agujero.",
  "names.humvil.conversation.8.participants.4.line.3": "¿Otra vez?.",
  "names.humvil.conversation.8.participants.4.line.4": "Llamad a %s, necesitamos que nos ayude a sacarlo.",
  "names.humvil.conversation.9.participants.4.line.1": "Este comercio es una estafa.",
  "names.humvil.conversation.9.participants.4.line.2": "Nadie te obliga a comprar, %s.",
  "names.humvil.conversation.9.participants.4.line.3": "Vamos chicos, no peleéis.",
  "names.humvil.conversation.9.participants.4.line.4": "%s siempre tiene los precios más altos, es verdad.",

  "names.humvil.conversation.1.participants.5.line.1": "La reunión del consejo comienza ahora.",
  "names.humvil.conversation.1.participants.5.line.2": "Propongo que trabajemos menos horas.",
  "names.humvil.conversation.1.participants.5.line.3": "Concuerco con lo que dice %s.",
  "names.humvil.conversation.1.participants.5.line.4": "Pero si no trabajamos, %s no nos dará esmeraldas.",
  "names.humvil.conversation.1.participants.5.line.5": "Ya... eso es verdad. Pues nada, vuelta al trabajo todos.",
  "names.humvil.conversation.2.participants.5.line.1": "Vaya, qué estructura más rara ha hecho %s.",
  "names.humvil.conversation.2.participants.5.line.2": "Parece como una especie de granja o algo... ¿no?",
  "names.humvil.conversation.2.participants.5.line.3": "Es un poco raro, ¿no creéis?",
  "names.humvil.conversation.2.participants.5.line.4": "A mí me gusta, da sombra.",
  "names.humvil.conversation.2.participants.5.line.5": "A mi también me gusta, está chula.",
  "names.humvil.conversation.3.participants.5.line.1": "Hrmm.",
  "names.humvil.conversation.3.participants.5.line.2": "Hrmm?",
  "names.humvil.conversation.3.participants.5.line.3": "Hrmm!",
  "names.humvil.conversation.3.participants.5.line.4": "Hrmm...",
  "names.humvil.conversation.3.participants.5.line.5": "Joder, que profundo hermano.",
  "names.humvil.conversation.4.participants.5.line.1": "Oye, ¿no crecen muy lento los cultivos?",
  "names.humvil.conversation.4.participants.5.line.2": "A este paso sale el GTA VI antes...",
  "names.humvil.conversation.4.participants.5.line.3": "Si, la verdad es que están tardando demasiado, que raro.",
  "names.humvil.conversation.4.participants.5.line.4": "Me parece que es porque a veces pisamos los cultivos sin querer.",
  "names.humvil.conversation.4.participants.5.line.5": "Si, creo que %s tiene razón.",
  "names.humvil.conversation.4.participants.5.line.6": "Tiene sentido... pues tened un poco más de cuidado porfa."
}
